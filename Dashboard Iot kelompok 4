<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IoT Dashboard - Smart Home</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background-color: #f0f2f5; margin: 0; padding: 20px; }
        .container { max-width: 800px; margin: 0 auto; }
        h1 { color: #333; text-align: center; }
        
        /* Grid Layout */
        .dashboard-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 20px; }
        
        /* Card Style */
        .card { background: white; padding: 20px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); text-align: center; }
        .card h3 { margin-top: 0; color: #555; }
        .value { font-size: 2em; font-weight: bold; color: #2c3e50; }
        
        /* Status Colors */
        .temp { color: #e74c3c; }
        .humidity { color: #3498db; }
        .light { color: #f1c40f; }

        /* Button Control */
        .btn { padding: 10px 20px; border: none; border-radius: 5px; cursor: pointer; font-weight: bold; transition: 0.3s; }
        .btn-on { background-color: #2ecc71; color: white; }
        .btn-off { background-color: #e74c3c; color: white; }
        .btn:hover { opacity: 0.8; }

        /* Log Section */
        .log-section { margin-top: 30px; background: white; padding: 20px; border-radius: 10px; }
        .log-item { border-bottom: 1px solid #eee; padding: 10px 0; font-size: 0.9em; color: #666; }
    </style>
</head>
<body>

<div class="container">
    <h1>🏠 Smart Home Dashboard</h1>
    
    <div class="dashboard-grid">
        <!-- Card Suhu -->
        <div class="card">
            <h3>Suhu Ruangan</h3>
            <div class="value temp">26°C</div>
            <p>Normal</p>
        </div>

        <!-- Card Kelembapan -->
        <div class="card">
            <h3>Kelembapan</h3>
            <div class="value humidity">60%</div>
            <p>Cukup Lembab</p>
        </div>

        <!-- Card Lampu -->
        <div class="card">
            <h3>Status Lampu</h3>
            <div class="value light">ON</div>
            <button class="btn btn-off" onclick="alert('Mati!')">Matikan</button>
        </div>
    </div>

    <div class="log-section">
        <h3>📜 Riwayat Aktivitas</h3>
        <div class="log-item">[10:00] Sensor Suhu mengirim data: 26°C</div>
        <div class="log-item">[09:45] Lampu Kamar dinyalakan oleh User</div>
        <div class="log-item">[09:00] Sistem dimulai (Boot)</div>
    </div>
</div>

</body>
</html>